#!/bin/bash
# Local pre-commit hook. Activated by:
#     git config core.hooksPath .githooks
#
# Runs five independent gates. Each fails fast — failure in any gate blocks
# the commit:
#   1. lib-sync       — plugins/{vdm,vdm-git}/lib/ must stay byte-identical
#                       (caught by scripts/check-lib-sync.sh)
#   2. version-bump   — staged plugin file change requires bump in
#                       plugins/X/.claude-plugin/plugin.json; also asserts
#                       marketplace.json ↔ plugin.json parity unconditionally
#                       (caught by scripts/check-version-bump.sh)
#   3. skill-paths    — plugins/*/skills/**/SKILL.md and plugins/*/templates/*.md
#                       must use ${CLAUDE_PLUGIN_ROOT}, not dev-tree paths
#                       (caught by scripts/check-skill-paths.sh)
#   4. crystal        — workitems under docs/tasks/ with frontmatter status:done
#                       must have zero `- [ ]` checkboxes (crystal-cut DL #4)
#                       (caught by scripts/check-crystal-completion.sh)
#   5. gate red-tests — changing a gate re-runs tests/gates.test.sh, which
#                       breaks each invariant on purpose and asserts the gate
#                       goes red. Conditional (~15s) — fires only when a gate
#                       or the harness is staged.

set -eu

staged=$(git diff --cached --name-only)

# Gate 1 — lib-sync: only relevant when lib/ is staged.
if printf '%s\n' "$staged" | grep -qE '^plugins/(vdm|vdm-git)/lib/'; then
  scripts/check-lib-sync.sh
fi

# Gate 2 — version-bump. Unconditional: the script itself decides what applies.
# The bump check is internally conditional (it only looks at plugins with staged
# files), while the marketplace ↔ plugin.json parity check must run on every
# commit — committed drift has to stay visible even when nobody is touching the
# manifests.
scripts/check-version-bump.sh

# Gate 3 — skill-paths: invariant must hold on every commit, regardless of
# what's staged. Fast (single grep per file).
scripts/check-skill-paths.sh

# Gate 4 — crystal: defense-in-depth backup to the crystal-completion-guard
# PreToolUse hook. Catches IDE-direct edits that flip status:done without
# clearing `- [ ]` items. Only fires when something is staged under
# docs/tasks/ — otherwise no-op.
scripts/check-crystal-completion.sh

# Gate 5 — the gates' own red tests. A gate does not exist until you have
# watched it FAIL: green on a clean tree proves nothing, since `exit 0` is also
# green. The orphan audit shipped BLIND (`--` before grep's flags turned every
# --exclude into a filename) and passed every run for months — see
# docs/llm/soft-guidance-vs-deterministic-gates.md → "The orphan gate that never
# ran".
#
# Conditional, because the harness clones the repo and costs ~15s: it fires only
# when a gate script or the harness itself is staged. That is exactly when the
# cost is earned — you cannot change a gate without re-proving it still goes red.
if printf '%s\n' "$staged" | grep -qE '^(scripts/check-.*\.sh|plugins/vdm/scripts/check-doc-orphans\.sh|tests/gates\.test\.sh|\.githooks/pre-commit)$'; then
  echo "gates: a gate changed — re-running its red tests (~15s)…"
  bash tests/gates.test.sh
fi
