{
  "description": "Documentation sync reminder hook - adds context when code changes are detected",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/docs-sync-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
